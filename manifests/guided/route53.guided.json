{
  "schemaVersion": "1.2",
  "service": "route53",
  "protocol": "rest_json",
  "flows": [
    {
      "id": "l1-basic",
      "level": "L1",
      "steps": [{"id":"create","title":"Create hosted zone","operation":{"method":"POST","path":"/","body":"{\"Name\":\"{{inputs.resource_name}}.example.com\",\"CallerReference\":\"{{timestamp()}}\"}"},"captures":[{"name":"resource_name","source":"inputs.resource_name"}],"assertions":[{"kind":"status","target":"status","expected":"200"}]}],
      "cleanup": [{"id":"delete","title":"Delete hosted zone","operation":{"method":"DELETE","path":"/{{captures.resource_name}}"},"assertions":[{"kind":"status","target":"status","expected":"200"}]}]
    }
  ]
}
