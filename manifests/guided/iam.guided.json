{
  "schemaVersion": "1.2",
  "service": "iam",
  "protocol": "query",
  "flows": [
    {
      "id": "l1-basic",
      "level": "L1",
      "steps": [
        {
          "id": "create",
          "title": "Create role",
          "operation": { "method": "POST", "path": "/", "body": "Action=CreateRole&RoleName={{inputs.resource_name}}&AssumeRolePolicyDocument=%7B%7D&Version=2010-05-08" },
          "captures": [{ "name": "resource_name", "source": "inputs.resource_name" }],
          "assertions": [{ "kind": "status", "target": "status", "expected": "200" }]
        }
      ],
      "cleanup": [
        {
          "id": "delete",
          "title": "Delete role",
          "operation": { "method": "POST", "path": "/", "body": "Action=DeleteRole&RoleName={{captures.resource_name}}&Version=2010-05-08" },
          "assertions": [{ "kind": "status", "target": "status", "expected": "200" }]
        }
      ]
    }
  ]
}
