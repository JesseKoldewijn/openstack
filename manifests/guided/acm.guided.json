{
  "schemaVersion": "1.2",
  "service": "acm",
  "protocol": "rest_json",
  "flows": [
    {
      "id": "l1-basic",
      "level": "L1",
      "steps": [{"id":"create","title":"Create certificate","operation":{"method":"POST","path":"/","body":"{\"CertificateArn\":\"{{inputs.resource_name}}\"}"},"captures":[{"name":"resource_name","source":"inputs.resource_name"}],"assertions":[{"kind":"status","target":"status","expected":"200"}]}],
      "cleanup": [{"id":"delete","title":"Delete certificate","operation":{"method":"DELETE","path":"/{{captures.resource_name}}"},"assertions":[{"kind":"status","target":"status","expected":"200"}]}]
    }
  ]
}
