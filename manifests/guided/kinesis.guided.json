{
  "schemaVersion": "1.2",
  "service": "kinesis",
  "protocol": "json_target",
  "flows": [
    {
      "id": "l1-basic",
      "level": "L1",
      "steps": [{"id":"create","title":"Create stream","operation":{"method":"POST","path":"/","headers":{"x-amz-target":"Kinesis_20131202.CreateStream"},"body":"{\"StreamName\":\"{{inputs.resource_name}}\",\"ShardCount\":1}"},"captures":[{"name":"resource_name","source":"inputs.resource_name"}],"assertions":[{"kind":"status","target":"status","expected":"200"}]}],
      "cleanup": [{"id":"delete","title":"Delete stream","operation":{"method":"POST","path":"/","headers":{"x-amz-target":"Kinesis_20131202.DeleteStream"},"body":"{\"StreamName\":\"{{captures.resource_name}}\"}"},"assertions":[{"kind":"status","target":"status","expected":"200"}]}]
    }
  ]
}
