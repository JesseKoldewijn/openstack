{
  "schemaVersion": "1.2",
  "service": "secretsmanager",
  "protocol": "json_target",
  "flows": [
    {
      "id": "l1-basic",
      "level": "L1",
      "steps": [{"id":"create","title":"Create secret","operation":{"method":"POST","path":"/","headers":{"x-amz-target":"secretsmanager.CreateSecret"},"body":"{\"Name\":\"{{inputs.resource_name}}\",\"SecretString\":\"value\"}"},"captures":[{"name":"resource_name","source":"inputs.resource_name"}],"assertions":[{"kind":"status","target":"status","expected":"200"}]}],
      "cleanup": [{"id":"delete","title":"Delete secret","operation":{"method":"POST","path":"/","headers":{"x-amz-target":"secretsmanager.DeleteSecret"},"body":"{\"SecretId\":\"{{captures.resource_name}}\",\"ForceDeleteWithoutRecovery\":true}"},"assertions":[{"kind":"status","target":"status","expected":"200"}]}]
    }
  ]
}
