[
  {
    "id": "s3-put-large-object",
    "profile": "hot-path-deep",
    "service": "s3",
    "protocol": "rest-xml",
    "setup": [
      {
        "id": "s3-create-bucket",
        "protocol": "rest-xml",
        "command": ["s3api", "create-bucket", "--bucket", "{{bucket}}"],
        "expect_success": true,
        "capture_json": null
      }
    ],
    "operation": {
      "id": "s3-put-object-large",
      "protocol": "rest-xml",
      "command": [
        "s3api",
        "put-object",
        "--bucket",
        "{{bucket}}",
        "--key",
        "large-{{run_id}}.txt",
        "--body",
        "README.md"
      ],
      "expect_success": true,
      "capture_json": null
    },
    "cleanup": [
      {
        "id": "s3-delete-bucket",
        "protocol": "rest-xml",
        "command": ["s3api", "delete-bucket", "--bucket", "{{bucket}}"],
        "expect_success": true,
        "capture_json": null
      }
    ],
    "warmup_iterations": 3,
    "measured_iterations": 8,
    "operations_per_iteration": 50,
    "concurrency": 8
  },
  {
    "id": "sqs-send-burst",
    "profile": "hot-path-deep",
    "service": "sqs",
    "protocol": "query-xml",
    "setup": [
      {
        "id": "sqs-create-queue",
        "protocol": "query-xml",
        "command": ["sqs", "create-queue", "--queue-name", "{{queue}}"],
        "expect_success": true,
        "capture_json": null
      }
    ],
    "operation": {
      "id": "sqs-send-message-burst",
      "protocol": "query-xml",
      "command": [
        "sqs",
        "send-message",
        "--queue-url",
        "http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/{{queue}}",
        "--message-body",
        "deep-{{run_id}}"
      ],
      "expect_success": true,
      "capture_json": null
    },
    "cleanup": [
      {
        "id": "sqs-delete-queue",
        "protocol": "query-xml",
        "command": [
          "sqs",
          "delete-queue",
          "--queue-url",
          "http://sqs.us-east-1.localhost.localstack.cloud:4566/000000000000/{{queue}}"
        ],
        "expect_success": true,
        "capture_json": null
      }
    ],
    "warmup_iterations": 2,
    "measured_iterations": 8,
    "operations_per_iteration": 40,
    "concurrency": 10
  },
  {
    "id": "ddb-read-hot-key",
    "profile": "hot-path-deep",
    "service": "dynamodb",
    "protocol": "json",
    "setup": [
      {
        "id": "ddb-create-table",
        "protocol": "json",
        "command": [
          "dynamodb",
          "create-table",
          "--table-name",
          "{{table}}",
          "--attribute-definitions",
          "AttributeName=pk,AttributeType=S",
          "--key-schema",
          "AttributeName=pk,KeyType=HASH",
          "--billing-mode",
          "PAY_PER_REQUEST"
        ],
        "expect_success": true,
        "capture_json": null
      },
      {
        "id": "ddb-put-item",
        "protocol": "json",
        "command": [
          "dynamodb",
          "put-item",
          "--table-name",
          "{{table}}",
          "--item",
          "{\"pk\":{\"S\":\"hot\"},\"value\":{\"S\":\"v\"}}"
        ],
        "expect_success": true,
        "capture_json": null
      }
    ],
    "operation": {
      "id": "ddb-get-item-hot",
      "protocol": "json",
      "command": [
        "dynamodb",
        "get-item",
        "--table-name",
        "{{table}}",
        "--key",
        "{\"pk\":{\"S\":\"hot\"}}"
      ],
      "expect_success": true,
      "capture_json": null
    },
    "cleanup": [
      {
        "id": "ddb-delete-table",
        "protocol": "json",
        "command": ["dynamodb", "delete-table", "--table-name", "{{table}}"],
        "expect_success": true,
        "capture_json": null
      }
    ],
    "warmup_iterations": 3,
    "measured_iterations": 8,
    "operations_per_iteration": 50,
    "concurrency": 10
  },
